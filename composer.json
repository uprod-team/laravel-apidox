{
    "name": "privateevent/laravel",
    "description": "Auto-generated, beautifully styled API documentation page for Laravel apps. Zero-config, scans routes/api.php, reads PHPDoc and FormRequest rules.",
    "keywords": ["laravel", "api", "documentation", "docs", "rest", "webhooks", "sanctum"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Laurent Guyard",
            "email": "l.guyard@n2xlabs.com"
        }
    ],
    "support": {
        "issues": "https://github.com/uprod-team/laravel-apidox/issues",
        "source": "https://github.com/uprod-team/laravel-apidox"
    },
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "PrivateEvent\\Apidox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrivateEvent\\Apidox\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PrivateEvent\\Apidox\\ApidoxServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
